
<!DOCTYPE html>

<html lang="ro">

<head>

    <meta charset="UTF-8">
		<link rel="icon" type="image/png" sizes="1080x1080" href="https://invisionromania.cfd/images/invision.png">


    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Specter Romania - Server de Roleplay</title>

    <link rel="stylesheet" href="css/style.css">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css" />

    <!-- Added Swiper CSS for modern slider -->

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@10/swiper-bundle.min.css" />

    <style>
        :root {
            --primary-color: #661aca;
            --secondary-color: #c113e4;
            --accent-color: #6f2ec5;
            --highlight-color: #5710c9;
            --dark-bg: #1a0a0a;
            --card-bg: rgba(26, 10, 10, 0.8);
            --text-color: #f0f0f0;
        }

        body {
            background-color: #0a0000;
            color: var(--text-color);
            font-family: 'Arial', sans-serif;
            background-image: linear-gradient(to bottom, #200000, #0a0000);
        }

        .logo span {
            color: var(--primary-color);
        }

        .nav-links a:hover {
            color: var(--primary-color);
        }

        .btn.primary {
            background: linear-gradient(45deg, var(--primary-color), var(--secondary-color));
            box-shadow: 0 0 15px rgba(0, 89, 255, 0.5);
        }

        .btn.primary:hover {
            background: linear-gradient(45deg, var(--secondary-color), var(--primary-color));
            box-shadow: 0 0 20px rgba(0, 217, 255, 0.8));
        }

        .btn.secondary {
            border: 2px solid var(--primary-color);
            color: var(--primary-color);
        }

        .btn.secondary:hover {
            background: var(--primary-color);
            color: #fff;
        }

        .glow-effect {
            box-shadow: 0 0 10px var(--primary-color);
        }

        .neon-effect {
            text-shadow: 0 0 5px var(--primary-color);
        }

        .status-indicator.online {
            background-color: var(--primary-color);
            box-shadow: 0 0 10px var(--primary-color);
        }

        .section-title {
            color: var(--primary-color);
            text-shadow: 0 0 10px rgba(0, 183, 255, 0.5);
        }

        .feature-card:hover {
            box-shadow: 0 0 20px rgba(0, 153, 255, 0.5);
        }

        .feature-icon {
            color: var(--primary-color);
        }

        .stat-box:hover {
            box-shadow: 0 0 20px rgba(0, 162, 255, 0.5);
        }

        .counter {
            color: var(--primary-color);
        }

        .gallery-overlay {
            background: linear-gradient(to top, rgba(0, 117, 153, 0.9), transparent);
        }

        .product-badge {
            background-color: var(--primary-color);
        }

        .product-price {
            color: var(--primary-color);
        }

        .paypal-checkout {
            background: linear-gradient(45deg, var(--primary-color), var(--secondary-color));
        }

        .paypal-checkout:hover {
            background: linear-gradient(45deg, var(--secondary-color), var(--primary-color));
        }

        .join-link {
            background: linear-gradient(45deg, var(--primary-color), var(--secondary-color));
        }

        .join-link:hover {
            background: linear-gradient(45deg, var(--secondary-color), var(--primary-color));
        }

        .step-number {
            background-color: var(--primary-color);
        }

        .social-links a:hover {
            color: var(--primary-color);
        }

        .particle {
            background-color: var(--primary-color);
        }

        .glitch::before {
            text-shadow: -1px 0 var(--primary-color);
        }

        .glitch::after {
            text-shadow: -1px 0 var(--secondary-color);
        }

        header {
            box-shadow: 0 2px 10px rgba(25, 0, 255, 0.3);
        }
    </style>

</head>

<body>

    <div class="bg-particles"></div>

    <header>

        <nav>

            <div class="logo" data-aos="fade-right" data-aos-duration="1000">

                <h1>Specter<span>Romania</span></h1>

            </div>

            <div class="nav-toggle">

                <i class="fas fa-bars"></i>

            </div>

            <ul class="nav-links">

                <li data-aos="fade-down" data-aos-delay="100"><a href="#home">Acasă</a></li>

                <li data-aos="fade-down" data-aos-delay="200"><a href="#about">Despre</a></li>

                <li data-aos="fade-down" data-aos-delay="300"><a href="#features">Caracteristici</a></li>


                <li data-aos="fade-down" data-aos-delay="500"><a href="#shop">Shop</a></li>

                <li data-aos="fade-down" data-aos-delay="600"><a href="#join">Alătură-te</a></li>

            </ul>

        </nav>

    </header>



    <section id="home" class="hero">

        <div class="hero-content">

            <h1 data-aos="zoom-in" data-aos-duration="1200" class="glitch" data-text="Specter Romania">Specter Romania</h1>

            <h2 data-aos="zoom-in" data-aos-duration="1400" class="cyberpunk-text">Experiență Reala de Roleplay FiveM</h2>

            <p data-aos="fade-up" data-aos-duration="1600">Cufundă-te într-o lume realistă de roleplay cu scripturi personalizate, economie unică și comunitate activă.</p>

            <div class="cta-buttons" data-aos="fade-up" data-aos-duration="1800">

                <a href="#join" class="btn primary glow-effect">Alătură-te Acum</a>

                <a href="#features" class="btn secondary neon-effect">Explorează</a>


            </div>

            <!-- Added server status indicator -->


        </div>

        <div class="hero-overlay"></div>

        <div class="hero-particles"></div>

    </section>



    <section id="about" class="about">

        <div class="container">

            <h2 class="section-title reveal-text" data-aos="fade-right">Despre Serverul Nostru</h2>

            <div class="about-content">

                <div class="about-text" data-aos="fade-right" data-aos-delay="200">

                    <p>Specter Romania este un server premium de roleplay FiveM dedicat oferirii celei mai captivante și realiste experiențe de joc. Serverul nostru prezintă scripturi create special, un sistem economic unic și o echipă dedicată de administratori.</p>

                    <p>Fondat în 2026, am construit o comunitate înfloritoare de jucători concentrată pe interacțiuni RP de înaltă calitate. Fie că vrei să fii polițist, criminal, proprietar de afacere sau simplu cetățean, Invision Romania oferă posibilități nelimitate.</p>

                </div>

                <div class="about-stats" data-aos="fade-left" data-aos-delay="400">

                    <div class="stat-box hover3d">

                        <div class="stat-box-inner">

                            <i class="fas fa-users"></i>

                            <h3>Comunitate Activă</h3>

                            <p>Alătură-te sutelor de jucători în lumea noastră vibrantă de roleplay</p>

                            <span class="counter" data-count="20">0+</span>

                        </div>

                    </div>

                    <div class="stat-box hover3d">

                        <div class="stat-box-inner">

                            <i class="fas fa-code"></i>

                            <h3>Scripturi Personalizate</h3>

                            <p>Experimentează mecanici de joc unice care nu se găsesc în altă parte</p>

                            <span class="counter" data-count="50">0+</span>

                        </div>

                    </div>

                    <div class="stat-box hover3d">

                        <div class="stat-box-inner">

                            <i class="fas fa-headset"></i>

                            <h3>Staff Dedicat</h3>

                            <p>Echipa noastră este mereu disponibilă pentru a ajuta și îmbunătăți serverul</p>

                            <span class="counter" data-count="15">0+</span>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </section>



    <section id="features" class="features">

        <div class="container">

            <h2 class="section-title reveal-text" data-aos="fade-right">Ce Ne Face Speciali</h2>

            <div class="features-grid">

                <div class="feature-card hover3d" data-aos="flip-up" data-aos-delay="100">

                    <div class="feature-card-inner">

                        <div class="feature-icon"><i class="fas fa-briefcase"></i></div>

                        <h3>Joburi Realiste</h3>

                        <p>Multiple cariere cu progresie și gameplay unic</p>

                    </div>

                </div>

                <div class="feature-card hover3d" data-aos="flip-up" data-aos-delay="200">

                    <div class="feature-card-inner">

                        <div class="feature-icon"><i class="fas fa-car"></i></div>

                        <h3>Vehicule Personalizate</h3>

                        <p>Modificări exclusive și manevrabilitate realistă</p>

                    </div>

                </div>

                <div class="feature-card hover3d" data-aos="flip-up" data-aos-delay="300">

                    <div class="feature-card-inner">

                        <div class="feature-icon"><i class="fas fa-home"></i></div>

                        <h3>Sistem de Proprietăți</h3>

                        <p>Deține case, afaceri și personalizează proprietățile tale</p>

                    </div>

                </div>

                <div class="feature-card hover3d" data-aos="flip-up" data-aos-delay="400">

                    <div class="feature-card-inner">

                        <div class="feature-icon"><i class="fas fa-money-bill-wave"></i></div>

                        <h3>Economie Dinamică</h3>

                        <p>Economie controlată de jucători cu monede multiple și investiții</p>

                    </div>

                </div>

                <div class="feature-card hover3d" data-aos="flip-up" data-aos-delay="500">

                    <div class="feature-card-inner">

                        <div class="feature-icon"><i class="fas fa-shield-alt"></i></div>

                        <h3>Poliție & Servicii Medicale</h3>

                        <p>Servicii de urgență bine structurate cu grade și echipamente</p>

                    </div>

                </div>

                <div class="feature-card hover3d" data-aos="flip-up" data-aos-delay="600">

                    <div class="feature-card-inner">

                        <div class="feature-icon"><i class="fas fa-users"></i></div>

                        <h3>Comunitate RP Activă</h3>

                        <p>Scenarii captivante și evenimente regulate pentru toți jucătorii</p>

                    </div>

                </div>

            </div>

        </div>

    </section>




    <!-- New Shop Section -->

    <section id="shop" class="shop">

        <div class="container">

            <h2 class="section-title reveal-text" data-aos="fade-right">Shop VIP</h2>

            <p class="shop-intro" data-aos="fade-up">Obține acces la beneficii exclusive și susține serverul nostru cu pachete VIP speciale</p>

            

            <div class="products-grid" data-aos="fade-up" data-aos-delay="200">

                <!-- Bronze VIP -->

                <div class="product-card hover3d bronze">

                    <div class="product-card-inner">

                        <div class="product-badge">Începător</div>

                        <h3>VIP Bronze</h3>

                        <div class="product-price">5€</div>

                        <ul class="product-features">

                            <li><i class="fas fa-check"></i> Beneficii de bază pentru un boost rapid în joc</li>

                            <li><i class="fas fa-check"></i> Acces la funcții exclusive și mici bonusuri</li>

                        </ul>

                        <button class="btn primary paypal-checkout" data-product="vip-bronze" data-price="2">Cumpără Acum</button>

                    </div>

                </div>



                <!-- Silver VIP -->

                <div class="product-card hover3d silver">

                    <div class="product-card-inner">

                        <div class="product-badge">Popular</div>

                        <h3>VIP Silver</h3>

                        <div class="product-price">7€</div>

                        <ul class="product-features">

                            <li><i class="fas fa-check"></i> Tot ce oferă Bronze + extra beneficii</li>

                            <li><i class="fas fa-check"></i> Prioritate la login și funcții în plus</li>

                        </ul>

                        <button class="btn primary paypal-checkout" data-product="vip-silver" data-price="3">Cumpără Acum</button>

                    </div>

                </div>



                <!-- Gold VIP -->

                <div class="product-card hover3d gold">

                    <div class="product-card-inner">

                        <div class="product-badge">Recomandat</div>

                        <h3>VIP Gold</h3>

                        <div class="product-price">10€</div>

                        <ul class="product-features">

                            <li><i class="fas fa-check"></i> Pachet echilibrat cu avantaje solide</li>

                            <li><i class="fas fa-check"></i> Acces la comenzi speciale și bonusuri premium</li>

                        </ul>

                        <button class="btn primary paypal-checkout" data-product="vip-gold" data-price="4">Cumpără Acum</button>

                    </div>

                </div>



                <!-- Diamond VIP -->

                <div class="product-card hover3d diamond">

                    <div class="product-card-inner">

                        <div class="product-badge">Premium</div>

                        <h3>VIP Diamond</h3>

                        <div class="product-price">13€</div>

                        <ul class="product-features">

                            <li><i class="fas fa-check"></i> Pachet avansat pentru jucători activi</li>

                            <li><i class="fas fa-check"></i> Boost-uri mari + funcții exclusive de top</li>

                            <li><i class="fas fa-diamond"></i> Beneficii exclusve Diamond</li>

                        </ul>

                        <button class="btn primary paypal-checkout" data-product="vip-diamond" data-price="7">Cumpără Acum</button>

                    </div>

                </div>



                <!-- Emerald VIP -->

                <div class="product-card hover3d Emerald">

                    <div class="product-card-inner">

                        <div class="product-badge">Ultimate</div>

                        <h3>VIP Emerald </h3>

                        <div class="product-price">17€</div>

                        <ul class="product-features">

                            <li><i class="fas fa-check"></i> Cel mai OP pachet, cu cele mai multe beneficii</li>

                            <li><i class="fas fa-check"></i> Acces total la tot ce oferă serverul</li>

                            <li><i class="fas fa-check"></i> Bonusuri speciale + nume evidențiat în comunitate</li>

                        </ul>

                        <button class="btn primary paypal-checkout" data-product="vip-emerald" data-price="13">Cumpără Acum</button>

                    </div>

                </div>

                

                <!-- Mafie Custom -->

                <div class="product-card hover3d mafie-custom">

                    <div class="product-card-inner">

                        <div class="product-badge">Exclusiv</div>

                        <h3>Mafie Custom</h3>

                        <div class="product-price">10€</div>

                        <ul class="product-features">

                            <li><i class="fas fa-check"></i> Mapping personalizat - tu alegi stilul și locația</li>

                            <li><i class="fas fa-check"></i> Tu alegi numele mafiei</li>

                            <li><i class="fas fa-check"></i> Alege locația: oraș, pădure, zonă izolată etc.</li>

                            <li><i class="fas fa-check"></i> Mașini personalizate în garaj</li>

                        </ul>

                        <button class="btn primary paypal-checkout" data-product="mafie-custom" data-price="7">Cumpără Acum</button>

                    </div>

                </div>

            </div>



            <h2 class="section-title reveal-text" data-aos="fade-right" style="margin-top: 50px;">ID-uri Speciale</h2>

            <p class="shop-intro" data-aos="fade-up">ID-uri exclusive pe Specter România</p>

            

            <div class="products-grid" data-aos="fade-up" data-aos-delay="200">

                <!-- ID 8 -->

                <div class="product-card hover3d id-special">

                    <div class="product-card-inner">

                        <div class="product-badge">Ultra-Rar</div>

                        <h3>ID 8</h3>

                        <div class="product-price">20€</div>

                        <ul class="product-features">

                            <li><i class="fas fa-check"></i> ID unic, foarte rar</li>

                            <li><i class="fas fa-check"></i> Prestigiu maxim în comunitate</li>

                            <li><i class="fas fa-gift"></i> Co fondator din partea casei*</li>

                            <li><i class="fas fa-info-circle"></i> *Se verifică vârsta (min. 14 ani)</li>

                        </ul>

                        <button class="btn primary paypal-checkout" data-product="id-6" data-price="50">Cumpără Acum</button>

                    </div>

                </div>

                

                <!-- ID 9 -->

                <div class="product-card hover3d id-special">

                    <div class="product-card-inner">

                        <div class="product-badge">Rar</div>

                        <h3>ID 9</h3>

                        <div class="product-price">15€</div>

                        <ul class="product-features">

                            <li><i class="fas fa-check"></i> ID extrem de rar</li>

                            <li><i class="fas fa-check"></i> Vizibilitate ridicată și respect garantat</li>

                            <li><i class="fas fa-gift"></i> Head of staff din partea casei*</li>

                            <li><i class="fas fa-info-circle"></i> *Se verifică vârsta (min. 14 ani)</li>

                        </ul>

                        <button class="btn primary paypal-checkout" data-product="id-7" data-price="40">Cumpără Acum</button>

                    </div>

                </div>

                

                <!-- ID 10 -->

                <div class="product-card hover3d id-special">

                    <div class="product-card-inner">

                        <div class="product-badge">Colecție</div>

                        <h3>ID 10</h3>

                        <div class="product-price">15€</div>

                        <ul class="product-features">

                            <li><i class="fas fa-check"></i> ID de colecție</li>

                            <li><i class="fas fa-check"></i> Ideal pentru jucători vechi sau lideri de facțiuni</li>

                        </ul>

                        <button class="btn primary paypal-checkout" data-product="id-8" data-price="30">Cumpără Acum</button>

                    </div>

                </div>

                

                <!-- ID 10+ -->

                <div class="product-card hover3d id-special">

                    <div class="product-card-inner">

                        <div class="product-badge">Personalizat</div>

                        <h3>ID 10+</h3>

                        <div class="product-price">10€</div>

                        <ul class="product-features">

                            <li><i class="fas fa-check"></i> ID-uri personalizate disponibile</li>

                            <li><i class="fas fa-check"></i> Perfect pentru a-ți lăsa amprenta pe server</li>

                        </ul>

                        <button class="btn primary paypal-checkout" data-product="id-9-plus" data-price="20">Cumpără Acum</button>

                    </div>

                </div>

            </div>

            

            <h2 class="section-title reveal-text" data-aos="fade-right" style="margin-top: 50px;">Unban Services</h2>

            <p class="shop-intro" data-aos="fade-up">Servicii de unban pentru FiveM și Discord</p>

            

            <div class="products-grid" data-aos="fade-up" data-aos-delay="200">

                <!-- FiveM Unban -->

                <div class="product-card hover3d unban-fivem">

                    <div class="product-card-inner">

                        <div class="product-badge">FiveM</div>

                        <h3>Unban FiveM</h3>

                        <div class="product-price">15€</div>

                        <ul class="product-features">

                            <li><i class="fas fa-check"></i> Deblocare completă pe serverul FiveM</li>

                            <li><i class="fas fa-check"></i> Procesare rapidă în maxim 24 ore</li>

                            <li><i class="fas fa-check"></i> Verificare și evaluare a cazului</li>

                        </ul>

                        <button class="btn primary paypal-checkout" data-product="unban-fivem" data-price="10">Cumpără Acum</button>

                    </div>

                </div>



                <!-- Discord Unban -->

                <div class="product-card hover3d unban-discord">

                    <div class="product-card-inner">

                        <div class="product-badge">Discord</div>

                        <h3>Unban Discord</h3>

                        <div class="product-price">10€</div>

                        <ul class="product-features">

                            <li><i class="fas fa-check"></i> Deblocare pe serverul Discord</li>

                            <li><i class="fas fa-check"></i> Acces complet la toate canalele</li>

                            <li><i class="fas fa-check"></i> Procesare în maxim 12 ore</li>

                        </ul>

                        <button class="btn primary paypal-checkout" data-product="unban-discord" data-price="5">Cumpără Acum</button>

                    </div>

                </div>

            </div>

            

            <h2 class="section-title reveal-text" data-aos="fade-right" style="margin-top: 50px;">Grade Staff</h2>

            <p class="shop-intro" data-aos="fade-up">Grade Staff disponibile pe Invision România</p>

            

            <div class="products-grid" data-aos="fade-up" data-aos-delay="200">

                <!-- Helper în teste -->

                <div class="product-card hover3d staff-grade">

                    <div class="product-card-inner">

                        <div class="product-badge">Începător</div>

                        <h3>Helper în teste</h3>

                        <div class="product-price">5€</div>

                        <ul class="product-features">

                            <li><i class="fas fa-check"></i> Primul pas în echipa de staff</li>

                            <li><i class="fas fa-check"></i> Acces limitat la comenzile de ajutor</li>

                        </ul>

                        <button class="btn primary paypal-checkout" data-product="helper-teste" data-price="1">Cumpără Acum</button>

                    </div>

                </div>

                

                <!-- Helper -->

                <div class="product-card hover3d staff-grade">

                    <div class="product-card-inner">

                        <div class="product-badge">Bază</div>

                        <h3>Helper</h3>

                        <div class="product-price">2.5€</div>

                        <ul class="product-features">

                            <li><i class="fas fa-check"></i> Acces extins la comenzi de suport</li>

                            <li><i class="fas fa-check"></i> Responsabilități oficiale în comunitate</li>

                        </ul>

                        <button class="btn primary paypal-checkout" data-product="helper" data-price="2.5">Cumpără Acum</button>

                    </div>

                </div>

                

                <!-- Moderator -->

                <div class="product-card hover3d staff-grade">

                    <div class="product-card-inner">

                        <div class="product-badge">Intermediar</div>

                        <h3>Moderator</h3>

                        <div class="product-price">4€</div>

                        <ul class="product-features">

                            <li><i class="fas fa-check"></i> Permisiuni de moderare avansate</li>

                            <li><i class="fas fa-check"></i> Gestionare a problemelor și a plângerilor jucătorilor</li>

                        </ul>

                        <button class="btn primary paypal-checkout" data-product="moderator" data-price="4">Cumpără Acum</button>

                    </div>

                </div>

                

                <!-- Super Moderator -->

                <div class="product-card hover3d staff-grade">

                    <div class="product-card-inner">

                        <div class="product-badge">Avansat</div>

                        <h3>Super Moderator</h3>

                        <div class="product-price">6€</div>

                        <ul class="product-features">

                            <li><i class="fas fa-check"></i> Putere mai mare de moderare</li>

                            <li><i class="fas fa-check"></i> Supravegherea helperilor și moderatorilor</li>

                        </ul>

                        <button class="btn primary paypal-checkout" data-product="super-moderator" data-price="6">Cumpără Acum</button>

                    </div>

                </div>

                

                <!-- Administrator -->

                <div class="product-card hover3d staff-grade">

                    <div class="product-card-inner">

                        <div class="product-badge">Premium</div>

                        <h3>Administrator</h3>

                        <div class="product-price">10€</div>

                        <ul class="product-features">

                            <li><i class="fas fa-check"></i> Acces la managementul serverului</li>

                            <li><i class="fas fa-check"></i> Răspundere pentru buna funcționare a comunității</li>

                        </ul>

                        <button class="btn primary paypal-checkout" data-product="administrator" data-price="10">Cumpără Acum</button>

                    </div>

                </div>

                

                <!-- Super Administrator -->

                <div class="product-card hover3d staff-grade">

